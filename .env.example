# 3 Agent Private Keys
# Generate with: openssl rand -hex 32 (prefix with 0x)
RESEARCH_AGENT_KEY=0x...
TRADING_AGENT_KEY=0x...
TREASURY_AGENT_KEY=0x...

# Monad Testnet
MONAD_RPC_URL=https://testnet-rpc.monad.xyz

# Unlink SDK + CLI
UNLINK_CHAIN=monad-testnet

# x402 (Monad facilitator)
X402_FACILITATOR_URL=https://x402-facilitator.molandak.org

# OpenRouter (LLM backend for agent brain)
# Get key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# Price feed URL (trading agent)
PRICE_FEED_URL=http://localhost:3002

# Deployer key (can reuse TREASURY_AGENT_KEY)
PRIVATE_KEY=0x...
AGENT_ADDRESS=0x...

# GhostVault (set after deploying — optional)
GHOST_VAULT_ADDRESS=

# Demo mode (set to true for cached responses, no LLM needed)
DEMO_MODE=false
